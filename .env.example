# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Groq API — ключ: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# OpenAI-совместимый endpoint Groq
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# Запасная модель, если основная упёрлась в лимит Groq
OPENAI_FALLBACK_MODEL=llama-3.1-8b-instant

# Optional tuning
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=300
MAX_HISTORY_MESSAGES=10
MAX_RAG_CHUNKS=3

# RAG: Supabase pgvector + OpenAI Embeddings
# Supabase: Project Settings -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# OpenAI (не Groq): https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIMENSIONS=1536
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100
RAG_SIMILARITY_THRESHOLD=0.55

# GitHub Actions (Settings -> Secrets -> Actions) — для workflow rag-knowledge.yml:
# SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, OPENAI_API_KEY

# Google Sheets webhook (см. scripts/google-apps-script.js)
GOOGLE_SHEETS_WEBHOOK_URL=

# Telegram chat ID менеджера для уведомлений (узнать: @userinfobot)
MANAGER_TELEGRAM_CHAT_ID=
